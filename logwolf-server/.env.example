# GitHub OAuth
# Create an app at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Restrict dashboard access — at least one of these must be set
# Comma-separated list of GitHub usernames
LOGWOLF_ALLOWED_GITHUB_USERS=
# Comma-separated list of GitHub org names (any member is allowed)
LOGWOLF_ALLOWED_GITHUB_ORGS=

# Secrets — generate with: openssl rand -hex 32
SESSION_SECRET=
INTERNAL_API_SECRET=

# API key used by the frontend to instrument itself
# Generate one from the dashboard after first boot, then paste it here and restart
API_KEY=

# Logger: how often the per-project retention cleanup runs (Go duration string, e.g. 1h, 30m)
# Default: 1h
CLEANUP_INTERVAL=